{
  "name": "stxt",
  "displayName": "STXT - Semantic Text",
  "description": "Semantic Text syntax (.stxt)",
  "version": "0.1.1",
  "publisher": "stxt-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/stxt-lang/stxt-vscode"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": ["stxt", "semantic text", "language", "syntax"],
  "icon": "images/icon.png",
  "activationEvents": [
    "onLanguage:stxt"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
    {
      "id": "stxt",
      "aliases": ["STXT (Semantic Text)","STXT"],
      "extensions": [".stxt"],
      "configuration": "./language-configuration.json"
    }],
    "configurationDefaults": {
      "[stxt]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": false,
        "editor.detectIndentation": false,
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": false
        },
        "editor.wordBasedSuggestions": "off",
        "editor.suggest.showWords": false
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
