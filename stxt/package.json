{
  "name": "stxt",
  "displayName": "stxt",
  "description": "Semantic Text syntax (.stxt)",
  "version": "0.0.1",
  "publisher": "stxt-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/stxt-lang/stxt-vscode"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
    {
      "id": "stxt",
      "aliases": ["STXT (Semantic Text)","STXT"],
      "extensions": [".stxt"],
      "configuration": "./language-configuration.json"
    }]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
